# Copy this file to .env and adjust values for your setup

PORT_HTTP=3000
PORT_WS=3001

# GPIO pin numbers (BCM numbering)
GPIO_BELL=17       # Doorbell button (active LOW, connect to GND when pressed)
GPIO_SERVO=18      # Servo SG90 signal wire (PWM capable pin)

# Camera settings
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=5

# Audio (ALSA device index, usually 0)
AUDIO_DEVICE=plughw:0,0
AUDIO_SAMPLE_RATE=16000
